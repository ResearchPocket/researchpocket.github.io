# Generated by Cargo
/debug/
/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

/test.jsonc
/.vscode/settings.json
/test.session.sql
# Private SQLite libraries may appear beneath any explicit --data-dir.
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Sanitized contract fixtures are deliberate repository artifacts.
!/tests/fixtures/**/*.sqlite
!/tests/fixtures/**/*.sqlite3
!/crates/**/tests/fixtures/**/*.sqlite
!/crates/**/tests/fixtures/**/*.sqlite3
/raindrop_export.csv
/test.json
/test.py
