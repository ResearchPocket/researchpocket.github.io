    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fake-indexeddb": "6.2.5",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
